---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CheatSheet from "../../components/CheatSheet.astro";
import { CHEAT_SHEET_GROUPS } from "../../lib/groups";
import { getLessonsInRange } from "../../lib/lessons";
import type { Dialogue } from "../../components/CheatSheet.astro";
import dialoguesData from "../../content/dialogues-01-68.json";
const allDialogues = (dialoguesData as { dialogues: Dialogue[] }).dialogues;
---

<BaseLayout
  title="Cheat sheets — Complete Spanish Reference"
  description="Key concepts, verbs, vocabulary, and example sentences for all lessons of the Complete Spanish course."
>
  <h1>Cheat sheets</h1>

  <div class="no-print" style="margin-bottom:0.75rem">
    <div style="display:flex;align-items:center;gap:1rem;margin-bottom:0.25rem">
      <span style="font-weight:600;font-size:0.85rem">Mode:</span>
      <label style="cursor:pointer;display:flex;align-items:center;gap:0.3rem;font-size:0.85rem">
        <input type="radio" name="mode" value="compact" checked id="mode-compact" /> Compact
      </label>
      <label style="cursor:pointer;display:flex;align-items:center;gap:0.3rem;font-size:0.85rem">
        <input type="radio" name="mode" value="full" id="mode-full" /> Full
      </label>
    </div>
    <p id="mode-description" style="font-size:0.8rem;color:var(--color-muted);margin:0">
      Compact mode hides supplementary content and collapses duplicate examples for a condensed view.
    </p>
  </div>

  <nav class="lesson-links no-print">
    {CHEAT_SHEET_GROUPS.map((g) => (
      <a href={`#${g.slug}`}>{g.label}</a>
    ))}
  </nav>

  {CHEAT_SHEET_GROUPS.map((g) => {
    const lessons = getLessonsInRange(g.start, g.end);
    return (
      <section id={g.slug}>
        <CheatSheet lessons={lessons} groupLabel={g.label} dialogues={allDialogues} />
      </section>
    );
  })}

  <script>
    const compactRadio = document.getElementById("mode-compact") as HTMLInputElement;
    const fullRadio = document.getElementById("mode-full") as HTMLInputElement;
    const desc = document.getElementById("mode-description");
    if (!compactRadio || !fullRadio || !desc) throw new Error("missing elements");

    const mode = new URLSearchParams(location.search).get("mode");
    const initialCompact = mode !== "full";
    compactRadio.checked = initialCompact;
    fullRadio.checked = !initialCompact;
    let compact = initialCompact;

    function applyMode() {
      const allSentenceRows = document.querySelectorAll("tr[data-show-in-mode]");

      for (const row of allSentenceRows) {
        const showInMode = row.getAttribute("data-show-in-mode");
        row.classList.toggle("is-hidden", compact && showInMode === "compact");
      }

      // Restripe
      for (const t of document.querySelectorAll("table")) {
        const sentenceRows = t.querySelectorAll("tbody > tr[data-show-in-mode]");
        let visibleIndex = 0;
        for (const row of sentenceRows) {
          const visible = !row.classList.contains("is-hidden");
          row.classList.toggle("row-alt", visible && visibleIndex++ % 2 === 1);
        }
      }

      // Update description
      desc!.textContent = compact
        ? "Compact mode hides supplementary content and collapses duplicate examples for a condensed view."
        : "Full mode shows every sentence including supplementary and duplicate examples.";
    }

    compactRadio.addEventListener("change", () => {
      if (!compactRadio.checked) return;
      compact = true;
      applyMode();
      history.replaceState(null, "", window.location.pathname);
    });

    fullRadio.addEventListener("change", () => {
      if (!fullRadio.checked) return;
      compact = false;
      applyMode();
      history.replaceState(null, "", window.location.pathname + "?mode=full");
    });

    applyMode();

    // Per-column toggle checkboxes (event delegation)
    document.addEventListener("change", (e) => {
      const target = e.target as HTMLElement;
      const table = target.closest("table");
      if (!table) return;
      if (target.matches("[data-toggle-es]")) {
        table.classList.toggle("hide-es", !target.checked);
      }
      if (target.matches("[data-toggle-en]")) {
        table.classList.toggle("hide-en", !target.checked);
      }
    });

    // Open collapsible sections when printing, collapse after
    function toggleSections(open: boolean) {
      for (const d of document.querySelectorAll<HTMLDetailsElement>("details.dialogue, details.sentences")) {
        d.open = open;
      }
    }
    if ("onbeforeprint" in window) {
      window.onbeforeprint = () => toggleSections(true);
      window.onafterprint = () => toggleSections(false);
    } else {
      window.matchMedia("print").addEventListener("change", (mql) => {
        toggleSections(mql.matches);
      });
    }
  </script>
</BaseLayout>
