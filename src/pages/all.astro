---
import BaseLayout from "../layouts/BaseLayout.astro";
import TranslationTable from "../components/TranslationTable.astro";
import { getAllLessons } from "../lib/lessons";

const lessons = getAllLessons();
const totalSentences = lessons.reduce((sum, l) => sum + l.sentences.length, 0);
const raw = import.meta.env.BASE_URL;
const base = raw.endsWith("/") ? raw : raw + "/";
---

<BaseLayout
  title="All sentence pairs — Complete Spanish Reference"
  description="Every available Spanish/English sentence pair from the Complete Spanish course, grouped by lesson."
>
  <h1>All sentence pairs</h1>
  <p lang="en">
    <span id="sentence-count">{totalSentences}</span> sentences across {lessons.length} lessons.
  </p>

  <div class="no-print" style="margin-bottom:0.75rem">
    <div style="display:flex;align-items:center;gap:1rem;margin-bottom:0.25rem">
      <span style="font-weight:600;font-size:0.85rem">Mode:</span>
      <label style="cursor:pointer;display:flex;align-items:center;gap:0.3rem;font-size:0.85rem">
        <input type="radio" name="mode" value="compact" checked id="mode-compact" /> Compact
      </label>
      <label style="cursor:pointer;display:flex;align-items:center;gap:0.3rem;font-size:0.85rem">
        <input type="radio" name="mode" value="full" id="mode-full" /> Full
      </label>
    </div>
    <p id="mode-description" style="font-size:0.8rem;color:var(--color-muted);margin:0">
      Compact mode hides supplementary content and collapses duplicate examples for a condensed view.
    </p>
  </div>

  <nav class="lesson-links no-print">
    {lessons.map((l) => (
      <a href={`#lesson-${l.number}`}>Lesson {l.number}</a>
    ))}
  </nav>

  <TranslationTable {lessons} />

  <script>
    const table = document.getElementById("sentence-table");
    const compactRadio = document.getElementById("mode-compact") as HTMLInputElement;
    const fullRadio = document.getElementById("mode-full") as HTMLInputElement;
    const desc = document.getElementById("mode-description");
    const countEl = document.getElementById("sentence-count");
    if (!table || !compactRadio || !fullRadio || !desc) throw new Error("missing elements");

    const mode = new URLSearchParams(location.search).get("mode");
    const initialCompact = mode !== "full";
    compactRadio.checked = initialCompact;
    fullRadio.checked = !initialCompact;
    let compact = initialCompact;

    function applyMode() {
      const rows = table.querySelectorAll("tbody tr:not(.lesson-header)");

      // First pass: hide compact-mode-only sentences
      for (const row of rows) {
        const showInMode = row.getAttribute("data-show-in-mode");
        row.classList.toggle("is-hidden", compact && showInMode === "compact");
      }

      // Second pass: auto-collapse remaining identical Spanish
      if (compact) {
        const visibleRows = Array.from(rows).filter(
          (r) => !r.classList.contains("is-hidden"),
        );
        const seen = new Map<string, HTMLElement[]>();

        for (const row of visibleRows) {
          const spanish = row.getAttribute("data-spanish") || "";
          if (seen.has(spanish)) {
            const first = seen.get(spanish)![0];
            const english = first.querySelector("td:last-child")!;
            const currentEnglish = row.querySelector("td:last-child")?.textContent || "";
            if (!english.textContent?.includes(currentEnglish)) {
              english.textContent += " / " + currentEnglish;
            }
            row.classList.add("is-hidden");
          } else {
            seen.set(spanish, [row as HTMLElement]);
          }
        }
      }

      // Update sentence count
      const visibleCount = Array.from(rows).filter(
        (r) => !r.classList.contains("is-hidden"),
      ).length;
      countEl!.textContent = String(visibleCount);

      // Restripe
      for (const t of document.querySelectorAll("table")) {
        const sentenceRows = t.querySelectorAll("tbody > tr[data-show-in-mode]");
        let visibleIndex = 0;
        for (const row of sentenceRows) {
          const visible = !row.classList.contains("is-hidden");
          row.classList.toggle("row-alt", visible && visibleIndex++ % 2 === 1);
        }
      }

      // Update description
      desc!.textContent = compact
        ? "Compact mode hides supplementary content and collapses duplicate examples for a condensed view."
        : "Full mode shows every sentence including supplementary and duplicate examples.";
    }

    compactRadio.addEventListener("change", () => {
      if (!compactRadio.checked) return;
      compact = true;
      applyMode();
      history.replaceState(null, "", window.location.pathname);
    });

    fullRadio.addEventListener("change", () => {
      if (!fullRadio.checked) return;
      compact = false;
      applyMode();
      history.replaceState(null, "", window.location.pathname + "?mode=full");
    });

    applyMode();
  </script>
</BaseLayout>
