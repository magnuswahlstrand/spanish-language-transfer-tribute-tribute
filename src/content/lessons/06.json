  "concepts": [
    "Regular -ar verbs: drop -ar, add -o, -as, -a, -amos, -an",
    "Hablar = to speak: hablo, hablas, habla, hablamos, hablan",
    "The verb ending tells you the subject — pronouns are optional",
    "Hablo = I speak (no need to say yo unless emphasising)"
  ],
