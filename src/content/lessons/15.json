    { "spanish": "Vivimos en Madrid.", "english": "We live in Madrid." },
    { "spanish": "¿Dónde vives?", "english": "Where do you live?" },
    { "spanish": "Escribo una carta.", "english": "I write a letter." },
    { "spanish": "No comprendo.", "english": "I don't understand." }
  ]
