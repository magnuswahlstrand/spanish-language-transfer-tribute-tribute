  "title": "Plurals — los and las",
  "status": "draft",
  "source": {
    "type": "tribute",
    "url": "https://languagetransfertribute.com/lessons/9/"
  },
  "concepts": [
    "Plural of el = los, plural of la = las",
    "Words ending in a vowel add -s: libro → libros",
    "Words ending in a consonant add -es: ciudad → ciudades",
    "Adjectives must agree in number and gender with the noun"
  ],
  "verbs": [],
  "keywords": [
    { "spanish": "los", "english": "the (masculine plural)" },
    { "spanish": "las", "english": "the (feminine plural)" },
