---
import type { Lesson } from "../lib/schema";

export interface Props {
  lessons: Lesson[];
  showLessonHeaders?: boolean;
}

const { lessons, showLessonHeaders = true } = Astro.props;
---

<table id="sentence-table">
  <thead>
    <tr>
      <th scope="col" lang="es">Spanish</th>
      <th scope="col" lang="en">English</th>
    </tr>
  </thead>
  <tbody>
    {lessons.map((lesson) => (
      <Fragment>
        {showLessonHeaders && (
          <tr id={`lesson-${lesson.number}`} class="lesson-header" data-lesson={lesson.number}>
            <th scope="colgroup" colspan="2" lang="en">
              Lesson {lesson.number}: {lesson.title}
            </th>
          </tr>
        )}
        {lesson.sentences.map((s, i) => (
          <tr
            data-lesson={lesson.number}
            data-spanish={s.spanish}
            data-english={s.english}
            data-show-in-mode={s.showInMode || "all"}
            data-index={i}
          >
            <td lang="es">{s.spanish}</td>
            <td lang="en">{s.english}</td>
          </tr>
        ))}
      </Fragment>
    ))}
  </tbody>
</table>
