---
import type { Lesson } from "../lib/schema";

export interface DialogueLine {
  speaker: string;
  spanish: string;
  english: string;
}

export interface Dialogue {
  lesson: number;
  title: string;
  focus: string[];
  notes?: string;
  lines: DialogueLine[];
}

export interface Props {
  lessons: Lesson[];
  groupLabel: string;
  dialogues?: Dialogue[];
}

const { lessons, groupLabel, dialogues = [] } = Astro.props;

const dialogueMap = new Map<number, Dialogue>();
for (const d of dialogues) {
  dialogueMap.set(d.lesson, d);
}
---

<style>
  details.dialogue .speaker-a td {
    font-weight: 700;
  }
  details.dialogue summary,
  details.sentences summary {
    font-size: 1.1rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    cursor: pointer;
  }
  table.hide-es td[lang="es"] {
    opacity: 0;
    transition: opacity 0.15s;
  }
  table.hide-es tr:hover td[lang="es"] {
    opacity: 1;
  }
  table.hide-en td[lang="en"] {
    opacity: 0;
    transition: opacity 0.15s;
  }
  table.hide-en tr:hover td[lang="en"] {
    opacity: 1;
  }
  .col-toggle {
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.15rem;
    margin-right: 0.3rem;
    vertical-align: middle;
  }
  .col-toggle input {
    width: 0.8rem;
    height: 0.8rem;
    cursor: pointer;
  }
</style>

<h1>{groupLabel} — Cheat sheet</h1>

{lessons.map((lesson) => (
  <section id={`lesson-${lesson.number}`}>
    <h2>
      {lesson.title}
    </h2>

    {lesson.concepts.length > 0 && (
      <>
        <h3>Key ideas</h3>
        <ul>
          {lesson.concepts.map((c) => (
            <li>{c}</li>
          ))}
        </ul>
      </>
    )}

    {lesson.verbs.length > 0 && (
      <>
        <h3>Verbs</h3>
        <table>
          <thead>
            <tr>
              <th scope="col" lang="es">
                <label class="col-toggle no-print" title="Show/hide Spanish column">
                  <input type="checkbox" data-toggle-es checked />
                </label>
                <span lang="es">Spanish</span>
              </th>
              <th scope="col" lang="en">
                <label class="col-toggle no-print" title="Show/hide English column">
                  <input type="checkbox" data-toggle-en checked />
                </label>
                <span lang="en">English</span>
              </th>
              <th scope="col">Notes</th>
            </tr>
          </thead>
          <tbody>
            {lesson.verbs.map((v) => (
              <tr>
                <td lang="es">{v.spanish}</td>
                <td lang="en">{v.english}</td>
                <td>{v.note}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </>
    )}

    {lesson.keywords.length > 0 && (
      <>
        <h3>Key words</h3>
        <table>
          <thead>
            <tr>
              <th scope="col" lang="es">
                <label class="col-toggle no-print" title="Show/hide Spanish column">
                  <input type="checkbox" data-toggle-es checked />
                </label>
                <span lang="es">Spanish</span>
              </th>
              <th scope="col" lang="en">
                <label class="col-toggle no-print" title="Show/hide English column">
                  <input type="checkbox" data-toggle-en checked />
                </label>
                <span lang="en">English</span>
              </th>
            </tr>
          </thead>
          <tbody>
            {lesson.keywords.map((k) => (
              <tr>
                <td lang="es">{k.spanish}</td>
                <td lang="en">{k.english}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </>
    )}

    {lesson.sentences.length > 0 && (
      <details class="sentences">
        <summary>Example sentences</summary>
        <table>
          <thead>
            <tr>
              <th scope="col" lang="es">
                <label class="col-toggle no-print" title="Show/hide Spanish column">
                  <input type="checkbox" data-toggle-es checked />
                </label>
                <span lang="es">Spanish</span>
              </th>
              <th scope="col" lang="en">
                <label class="col-toggle no-print" title="Show/hide English column">
                  <input type="checkbox" data-toggle-en checked />
                </label>
                <span lang="en">English</span>
              </th>
            </tr>
          </thead>
          <tbody>
            {lesson.sentences.map((s) => (
              <tr
                data-show-in-mode={s.showInMode || "all"}
              >
                <td lang="es">{s.spanish}</td>
                <td lang="en">{s.english}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </details>
    )}

    {(() => {
      const dia = dialogueMap.get(lesson.number);
      if (!dia) return null;
      return (
        <details class="dialogue">
          <summary>Dialog</summary>
          {dia.notes && (
            <p style={{ fontSize: "0.85rem", color: "var(--color-muted)", marginBottom: "0.5rem" }}>
              {dia.notes}
            </p>
          )}
          <table>
            <thead>
              <tr>
                <th scope="col" lang="es">
                  <label class="col-toggle no-print" title="Show/hide Spanish column">
                    <input type="checkbox" data-toggle-es checked />
                  </label>
                  <span lang="es">Spanish</span>
                </th>
                <th scope="col" lang="en">
                  <label class="col-toggle no-print" title="Show/hide English column">
                    <input type="checkbox" data-toggle-en checked />
                  </label>
                  <span lang="en">English</span>
                </th>
              </tr>
            </thead>
            <tbody>
              {dia.lines.map((line) => (
                <tr class={line.speaker === "A" ? "speaker-a" : ""}>
                  <td lang="es">{line.spanish}</td>
                  <td lang="en">{line.english}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </details>
      );
    })()}
  </section>
))}
