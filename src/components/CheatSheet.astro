---
import type { Lesson } from "../lib/schema";

export interface DialogueLine {
  speaker: string;
  spanish: string;
  english: string;
}

export interface Dialogue {
  lesson: number;
  title: string;
  focus: string[];
  notes?: string;
  lines: DialogueLine[];
}

export interface Props {
  lessons: Lesson[];
  groupLabel: string;
  dialogues?: Dialogue[];
}

const { lessons, groupLabel, dialogues = [] } = Astro.props;

const dialogueMap = new Map<number, Dialogue>();
for (const d of dialogues) {
  dialogueMap.set(d.lesson, d);
}
---

<style>
  details.dialogue .speaker-a td {
    font-weight: 700;
  }
</style>

<h1>{groupLabel} — Cheat sheet</h1>

{lessons.map((lesson) => (
  <section id={`lesson-${lesson.number}`}>
    <h2>
      Lesson {lesson.number}: {lesson.title}
    </h2>

    {lesson.concepts.length > 0 && (
      <>
        <h3>Key ideas</h3>
        <ul>
          {lesson.concepts.map((c) => (
            <li>{c}</li>
          ))}
        </ul>
      </>
    )}

    {lesson.verbs.length > 0 && (
      <>
        <h3>Verbs</h3>
        <table>
          <thead>
            <tr>
              <th scope="col" lang="es">Spanish</th>
              <th scope="col" lang="en">English</th>
              <th scope="col">Notes</th>
            </tr>
          </thead>
          <tbody>
            {lesson.verbs.map((v) => (
              <tr>
                <td lang="es">{v.spanish}</td>
                <td lang="en">{v.english}</td>
                <td>{v.note}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </>
    )}

    {lesson.keywords.length > 0 && (
      <>
        <h3>Key words</h3>
        <table>
          <thead>
            <tr>
              <th scope="col" lang="es">Spanish</th>
              <th scope="col" lang="en">English</th>
            </tr>
          </thead>
          <tbody>
            {lesson.keywords.map((k) => (
              <tr>
                <td lang="es">{k.spanish}</td>
                <td lang="en">{k.english}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </>
    )}

    {lesson.sentences.length > 0 && (
      <>
        <h3>Example sentences</h3>
        <table>
          <thead>
            <tr>
              <th scope="col" lang="es">Spanish</th>
              <th scope="col" lang="en">English</th>
            </tr>
          </thead>
          <tbody>
            {lesson.sentences.map((s) => (
              <tr
                data-show-in-mode={s.showInMode || "all"}
              >
                <td lang="es">{s.spanish}</td>
                <td lang="en">{s.english}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </>
    )}

    {(() => {
      const dia = dialogueMap.get(lesson.number);
      if (!dia) return null;
      return (
        <details class="dialogue">
          <summary>Dialog</summary>
          {dia.notes && (
            <p style={{ fontSize: "0.85rem", color: "var(--color-muted)", marginBottom: "0.5rem" }}>
              {dia.notes}
            </p>
          )}
          <table>
            <thead>
              <tr>
                <th scope="col" lang="es">Spanish</th>
                <th scope="col" lang="en">English</th>
              </tr>
            </thead>
            <tbody>
              {dia.lines.map((line) => (
                <tr class={line.speaker === "A" ? "speaker-a" : ""}>
                  <td lang="es">{line.spanish}</td>
                  <td lang="en">{line.english}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </details>
      );
    })()}
  </section>
))}
