    "eslint": "^8.57.0",
    "eslint-plugin-astro": "^1.3.0",
    "prettier": "^3.4.0",
    "prettier-plugin-astro": "^0.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "zod": "^3.24.0"
